{
  "name": "CoinNova Design Tokens",
  "version": "1.0.0",
  "description": "Import via Figma Variables or Tokens Studio. Source of truth: src/index.css + tailwind.config.js",
  "typography": {
    "fontFamily": {
      "sans": "IBM Plex Sans",
      "mono": "IBM Plex Mono"
    },
    "fontSize": {
      "display": { "size": 28, "lineHeight": 34, "weight": 600 },
      "h1": { "size": 22, "lineHeight": 28, "weight": 600 },
      "h2": { "size": 18, "lineHeight": 24, "weight": 600 },
      "h3": { "size": 16, "lineHeight": 22, "weight": 600 },
      "body": { "size": 15, "lineHeight": 22, "weight": 400 },
      "body-sm": { "size": 13, "lineHeight": 18, "weight": 400 },
      "caption": { "size": 11, "lineHeight": 16, "weight": 400 },
      "price-lg": { "size": 20, "lineHeight": 24, "weight": 600 },
      "price-md": { "size": 15, "lineHeight": 20, "weight": 500 },
      "price-sm": { "size": 13, "lineHeight": 18, "weight": 500 }
    }
  },
  "radius": {
    "sm": 6,
    "md": 10,
    "lg": 12,
    "xl": 16,
    "phone": 16
  },
  "layout": {
    "phoneWidth": 390,
    "phoneHeight": 812,
    "headerHeight": 48,
    "tabBarHeight": 56,
    "minTouchTarget": 44
  },
  "overlay": {
    "scrimDefault": "rgba(0,0,0,0.60)",
    "scrimHeavy": "rgba(0,0,0,0.70)",
    "zIndex": {
      "sheet": 40,
      "alert": 50,
      "toast": 60
    },
    "bottomSheet": {
      "maxWidth": 390,
      "radiusTop": 16,
      "paddingX": 16,
      "paddingBottom": 32,
      "handleWidth": 40,
      "handleHeight": 4
    },
    "toast": {
      "maxWidth": 358,
      "radius": 10,
      "durationMs": {
        "success": 3000,
        "error": 5000,
        "warning": 4000,
        "info": 3000
      }
    }
  },
  "themes": {
    "yellow-black": {
      "base": "#000000",
      "elevated": "#121212",
      "sunken": "#0A0A0A",
      "border": "#2A2A2A",
      "border-subtle": "#1A1A1A",
      "primary": "#FFFFFF",
      "primary-muted": "#737373",
      "secondary": "#A3A3A3",
      "brand": "#FFCC00",
      "brand-hover": "#E6B800",
      "brand-dark": "#000000",
      "success": "#22C55E",
      "danger": "#EF4444"
    },
    "green-white": {
      "base": "#FFFFFF",
      "elevated": "#F4F4F5",
      "sunken": "#FAFAFA",
      "border": "#E4E4E7",
      "border-subtle": "#F0F0F2",
      "primary": "#0A0A0A",
      "primary-muted": "#71717A",
      "secondary": "#52525B",
      "brand": "#7BEA0C",
      "brand-hover": "#6BD40A",
      "brand-dark": "#0A0A0A",
      "success": "#16A34A",
      "danger": "#DC2626"
    },
    "green-black": {
      "base": "#000000",
      "elevated": "#141414",
      "sunken": "#0A0A0A",
      "border": "#2A2A2A",
      "border-subtle": "#1A1A1A",
      "primary": "#FFFFFF",
      "primary-muted": "#737373",
      "secondary": "#A3A3A3",
      "brand": "#7BEA0C",
      "brand-hover": "#8EFB1A",
      "brand-dark": "#000000",
      "success": "#7BEA0C",
      "danger": "#EF4444"
    }
  }
}
